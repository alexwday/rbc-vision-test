# RBC Vision Test - Environment Configuration
#
# Copy this file to .env and fill in the values for your environment.
# The application will automatically load this file.

# =============================================================================
# LOCAL DEVELOPMENT (using OpenAI API directly)
# =============================================================================
# Set OPENAI_API_KEY to use local mode. When set, OAuth settings are ignored.

OPENAI_API_KEY=sk-your-api-key-here

# VISION_MODEL is required (no default)
VISION_MODEL=gpt-4.1

# =============================================================================
# RBC PRODUCTION (using Azure endpoint with OAuth)
# =============================================================================
# For RBC deployment, leave OPENAI_API_KEY unset and configure these:

# AZURE_BASE_URL=https://your-azure-endpoint.openai.azure.com/
# OAUTH_URL=https://your-oauth-endpoint/token
# CLIENT_ID=your-client-id
# CLIENT_SECRET=your-client-secret
# VISION_MODEL=your-vision-model-deployment-name
